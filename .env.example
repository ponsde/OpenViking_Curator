# ─── OpenViking ──────────────────────────────────────────────
# Path to your existing ov.conf (required)
OPENVIKING_CONFIG_FILE=/path/to/your/ov.conf

# OV data directory (default: ./data)
OV_DATA_PATH=./data

# Optional: connect to a remote OV HTTP server instead of embedded mode
# Use this when OV is running as a separate service (e.g. in Docker)
# OV_BASE_URL=http://127.0.0.1:9100

# ─── LLM (review, judge, conflict detection) ─────────────────
# Any OpenAI-compatible endpoint
CURATOR_OAI_BASE=https://your-llm-api.com/v1
CURATOR_OAI_KEY=sk-your-key

# Judge model (strong model recommended — used for quality review)
# Comma-separated fallback chain: first available is used
# CURATOR_JUDGE_MODELS=gpt-4o,gpt-4o-mini

# Router model (fast/cheap model is fine here)
# CURATOR_ROUTER_MODELS=gpt-4o-mini

# ─── External Search ─────────────────────────────────────────
# Grok is recommended for real-time web search.
# Any OAI-compatible endpoint also works.
CURATOR_GROK_BASE=https://your-grok-endpoint/v1
CURATOR_GROK_KEY=your-grok-key
CURATOR_GROK_MODEL=grok-4-fast

# Comma-separated list of search providers (tried in order, first success wins)
# Available: grok, oai, duckduckgo, tavily
# CURATOR_SEARCH_PROVIDERS=grok,duckduckgo,tavily

# Tavily API key (required if "tavily" is in CURATOR_SEARCH_PROVIDERS)
# Get your key at: https://app.tavily.com
# CURATOR_TAVILY_KEY=tvly-your-key

# (Legacy) single provider override — use CURATOR_SEARCH_PROVIDERS instead
# CURATOR_SEARCH_PROVIDER=grok

# ─── Coverage Thresholds ─────────────────────────────────────
# These control when local OV knowledge is "good enough" vs when to search externally.
# Tune these based on your embedding model and knowledge base size.
# Defaults work well for a mid-size OV instance with bge-m3 embeddings.
#
# local_sufficient: top OV score must exceed this + ≥2 results
#   Lower → triggers more external searches (more fresh, higher cost)
#   Higher → relies more on local KB (faster, cheaper, may miss fresh info)
# CURATOR_THRESHOLD_COV_SUFFICIENT=0.55    # default: 0.55  (prod: 0.60)
#
# local_marginal: triggers external search but local context still used
# CURATOR_THRESHOLD_COV_MARGINAL=0.45      # default: 0.45
#
# low_coverage: below this → treat as "no useful local results"
# CURATOR_THRESHOLD_COV_LOW=0.35           # default: 0.35
#
# L0 sufficient: abstract alone is good enough (skip L1/L2)
# CURATOR_THRESHOLD_L0_SUFFICIENT=0.62     # default: 0.62
#
# L1 sufficient: overview is good enough (skip L2 full read)
# CURATOR_THRESHOLD_L1_SUFFICIENT=0.50     # default: 0.50

# Max number of full-text (L2) reads per pipeline run (default: 2)
# Higher = more context but more tokens. Lower = faster, cheaper.
# CURATOR_MAX_L2_DEPTH=2

# L0/L1 auto-summarization on ingest (opt-in, requires OAI_BASE)
# Calls LLM once per ingest to generate L0 abstract (~80 tokens) and
# L1 overview (key-point list). Stored in curator_meta header + resource metadata.
# Disabled by default to avoid extra LLM cost per ingest.
# CURATOR_AUTO_SUMMARIZE=0
# CURATOR_SUMMARIZE_MODELS=gpt-4o-mini   # defaults to CURATOR_ROUTER_MODELS

# ─── Feedback & Dedup ────────────────────────────────────────
# File for storing up/down/adopt feedback signals per URI
# CURATOR_FEEDBACK_FILE=./feedback.json

# Max score delta applied by feedback signals (conservative — OV score dominates)
# CURATOR_FEEDBACK_WEIGHT=0.10

# File for dedup scan history (skips already-checked pairs)
# CURATOR_DEDUP_LOG=./data/dedup_log.json

# ─── Advanced ────────────────────────────────────────────────
# Enable LLM-based routing (uses one extra LLM call per query)
# 0 = rule-only routing (fast, no extra cost)
# CURATOR_LLM_ROUTE=0

# Save each pipeline run as a case file for debugging
# CURATOR_CAPTURE_CASE=1

# Curator working directory (cases, query logs, curated docs)
# CURATOR_DATA_PATH=./data

# Metadata version tag embedded in ingested docs
# CURATOR_VERSION=0.1.0

# LLM call retry settings
# CURATOR_CHAT_RETRY_MAX=3
# CURATOR_CHAT_RETRY_BACKOFF_SEC=0.6

# Conflict resolution strategy: auto | local | external | human
# auto = ingest external if preferred by judge + no conflict
# local = always prefer local, never ingest
# external = always prefer external
# human = block ingest on conflict, log to data/pending_review.jsonl
# CURATOR_CONFLICT_STRATEGY=auto

# ─── Background Scheduler ─────────────────────────────────────
# Enable background maintenance jobs (freshness scan + strengthen + governance)
# CURATOR_SCHEDULER_ENABLED=0

# Freshness scan: re-search stale resources
# CURATOR_FRESHNESS_INTERVAL_HOURS=24
# CURATOR_FRESHNESS_STALE_THRESHOLD=0.4

# Weak topic strengthening: proactively fill coverage gaps (fully automatic)
# CURATOR_STRENGTHEN_INTERVAL_HOURS=168
# CURATOR_STRENGTHEN_TOP_N=3

# ─── Automated Governance ────────────────────────────────────
# Weekly governance cycle: audit + flag + proactive search + report
# CURATOR_GOVERNANCE_ENABLED=0
# CURATOR_GOVERNANCE_INTERVAL_HOURS=168
# CURATOR_GOVERNANCE_MODE=normal          # normal | team (team adds full audit trail)
# CURATOR_GOVERNANCE_MAX_PROACTIVE=5      # max proactive search queries per cycle
# CURATOR_GOVERNANCE_LOOKBACK_DAYS=30     # query log analysis window
# CURATOR_GOVERNANCE_DRY_RUN=0            # 1 = audit only, no writes
# CURATOR_GOVERNANCE_REPLACES_STRENGTHEN=0  # 1 = skip standalone strengthen when governance is on
